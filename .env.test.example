# Integration Test Environment Variables
# Copy this file to .env.test and fill in actual values

# ========================================
# Test Database
# ========================================
# Use a separate database for integration tests
# Default: PostgreSQL on port 5433 (via docker-compose.test.yml)
DATABASE_URL_TEST=postgresql://test:test@localhost:5433/templify_test

# ========================================
# Mock Services
# ========================================
# Mock job-runner service (runs locally during tests)
JOB_RUNNER_BASE_URL=http://localhost:3001
JOB_RUNNER_TOKEN=test-token-12345

# ========================================
# Encryption & Security
# ========================================
# Test encryption key (NOT for production use)
# Must be at least 32 characters long
ENCRYPTION_KEY=test-encryption-key-must-be-32-characters-long

# ========================================
# Upstash Redis (mocked in tests)
# ========================================
KV_REST_API_URL=http://localhost:8079
KV_REST_API_TOKEN=test-token

# ========================================
# Clerk (optional for integration tests)
# ========================================
# Only needed if testing Clerk-specific functionality
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# CLERK_SECRET_KEY=sk_test_xxxxx

# ========================================
# Vercel Blob (mocked in tests)
# ========================================
# Not required - Blob operations are mocked

# ========================================
# PostHog (optional, can be disabled for tests)
# ========================================
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ========================================
# Sentry (optional, can be disabled for tests)
# ========================================
# SENTRY_DSN=
