<!DOCTYPE html>
<html>
<head>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Georgia', serif;
      color: #111;
      line-height: 1.7;
      background: #fff;
      padding: 48px;
    }
    .invoice-container {
      max-width: 720px;
      margin: 0 auto;
    }
    .invoice-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding-bottom: 24px;
      border-bottom: 1px solid #111;
      margin-bottom: 40px;
    }
    .invoice-title {
      font-size: 32px;
      font-weight: normal;
      letter-spacing: 4px;
      text-transform: uppercase;
    }
    .invoice-details {
      text-align: right;
      font-size: 13px;
      color: #555;
    }
    .invoice-id {
      font-weight: bold;
      color: #111;
      margin-bottom: 2px;
    }
    .invoice-parties {
      display: flex;
      justify-content: space-between;
      margin-bottom: 48px;
      gap: 40px;
    }
    .party-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #888;
      margin-bottom: 8px;
    }
    .party-name {
      font-size: 14px;
      font-weight: bold;
      margin-bottom: 4px;
    }
    .party-detail {
      font-size: 13px;
      color: #444;
      line-height: 1.8;
    }
    .invoice-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 32px;
      font-size: 13px;
    }
    .invoice-table th {
      text-align: left;
      padding: 8px 0;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #888;
      border-bottom: 1px solid #ddd;
      font-weight: normal;
    }
    .invoice-table th:nth-child(n+2) { text-align: right; }
    .invoice-table td {
      padding: 12px 0;
      border-bottom: 1px solid #f0f0f0;
      color: #222;
    }
    .invoice-table td:nth-child(n+2) { text-align: right; }
    .invoice-totals {
      margin-left: auto;
      width: 240px;
      font-size: 13px;
    }
    .total-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      color: #555;
      border-bottom: 1px solid #f0f0f0;
    }
    .total-row.grand {
      border-bottom: none;
      border-top: 1px solid #111;
      padding-top: 10px;
      margin-top: 4px;
      font-weight: bold;
      font-size: 15px;
      color: #111;
    }
    .invoice-footer {
      margin-top: 56px;
      padding-top: 24px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #888;
    }
    .invoice-footer p + p { margin-top: 4px; }
  </style>
</head>
<body>
  <div class="invoice-container">
    <div class="invoice-header">
      <div class="invoice-title">{{title}}</div>
      <div class="invoice-details">
        <div class="invoice-id">{{invoiceNumber}}</div>
        <div>{{invoiceDate}}</div>
      </div>
    </div>

    <div class="invoice-parties">
      <div>
        <div class="party-label">From</div>
        <div class="party-name">{{from.company}}</div>
        <div class="party-detail">{{from.address1}}<br/>{{from.address2}}<br/>{{from.email}}</div>
      </div>
      <div>
        <div class="party-label">Bill To</div>
        <div class="party-name">{{to.company}}</div>
        <div class="party-detail">{{to.address1}}<br/>{{to.address2}}<br/>{{to.email}}</div>
      </div>
    </div>

    <table class="invoice-table">
      <thead>
        <tr>
          <th>Description</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>{{description}}</td>
          <td>{{quantity}}</td>
          <td>{{price}}</td>
          <td>{{total}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="invoice-totals">
      <div class="total-row">
        <span>Subtotal</span><span>{{totals.subtotal}}</span>
      </div>
      <div class="total-row">
        <span>{{totals.taxLabel}}</span><span>{{totals.tax}}</span>
      </div>
      {{#if totals.discount}}
      <div class="total-row">
        <span>Discount</span><span>{{totals.discount}}</span>
      </div>
      {{/if}}
      <div class="total-row grand">
        <span>Total</span><span>{{totals.grandTotal}}</span>
      </div>
    </div>

    <div class="invoice-footer">
      <p>{{footer.thankYouMessage}}</p>
      <p>{{footer.paymentTerms}}</p>
    </div>
  </div>
</body>
</html>
