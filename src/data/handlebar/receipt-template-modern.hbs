<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #1e293b;
      line-height: 1.5;
      background-color: #f8fafc;
      padding: 32px 16px;
    }
    .receipt-container {
      max-width: 400px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(79, 70, 229, 0.10);
      overflow: hidden;
    }
    .receipt-header {
      background-color: #4f46e5;
      padding: 28px 28px 24px;
      text-align: center;
    }
    .receipt-title {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
      margin-bottom: 8px;
    }
    .company-name {
      font-size: 22px;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 6px;
    }
    .company-details {
      font-size: 12px;
      color: rgba(255,255,255,0.65);
      line-height: 1.6;
    }
    .receipt-body { padding: 24px 28px; }
    .divider {
      height: 1px;
      background-color: #e2e8f0;
      margin: 16px 0;
    }
    .meta-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      margin-bottom: 4px;
    }
    .meta-label { color: #64748b; text-transform: uppercase; letter-spacing: 0.8px; font-weight: 600; font-size: 10px; }
    .meta-value { color: #0f172a; font-weight: 600; font-size: 13px; }
    .customer-block {
      background: #f8fafc;
      border-radius: 8px;
      padding: 12px 16px;
      margin: 16px 0;
    }
    .customer-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #4f46e5; margin-bottom: 4px; }
    .customer-name { font-size: 14px; font-weight: 600; color: #0f172a; }
    .customer-email { font-size: 12px; color: #64748b; }
    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      margin-top: 4px;
    }
    .items-table th {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #64748b;
      padding: 6px 4px 8px;
      border-bottom: 2px solid #4f46e5;
      text-align: left;
    }
    .items-table th:nth-child(2),
    .items-table th:nth-child(3) { text-align: center; }
    .items-table th:nth-child(4) { text-align: right; }
    .items-table td {
      padding: 10px 4px;
      border-bottom: 1px solid #f1f5f9;
      color: #1e293b;
    }
    .items-table td:nth-child(2),
    .items-table td:nth-child(3) { text-align: center; }
    .items-table td:nth-child(4) { text-align: right; font-weight: 600; }
    .totals-block { margin-top: 12px; }
    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      padding: 4px 0;
      color: #475569;
    }
    .grand-total {
      display: flex;
      justify-content: space-between;
      font-size: 17px;
      font-weight: 700;
      color: #0f172a;
      padding: 12px 16px;
      background: #f0f4ff;
      border-radius: 8px;
      margin-top: 8px;
    }
    .grand-total-accent { color: #4f46e5; }
    .payment-block { margin-top: 16px; }
    .payment-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #4f46e5; margin-bottom: 6px; }
    .payment-value { font-size: 13px; color: #0f172a; }
    .barcode-block { text-align: center; margin-top: 20px; }
    .barcode-visual {
      display: inline-block;
      padding: 10px 16px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      font-size: 11px;
      color: #64748b;
      letter-spacing: 1px;
      font-family: monospace;
    }
    .receipt-footer {
      background: #f8fafc;
      padding: 20px 28px;
      text-align: center;
      font-size: 12px;
      color: #64748b;
      border-top: 1px solid #e2e8f0;
    }
    .receipt-footer p { margin-bottom: 4px; }
    .thank-you { font-size: 14px; font-weight: 700; color: #4f46e5; margin-bottom: 6px; }
  </style>
</head>
<body>
  <div class="receipt-container">
    <div class="receipt-header">
      <div class="receipt-title">{{receiptTitle}}</div>
      <div class="company-name">{{company.name}}</div>
      <div class="company-details">{{{company.address}}}<br />Tel: {{company.phone}}</div>
    </div>

    <div class="receipt-body">
      <div class="meta-row">
        <div>
          <div class="meta-label">Receipt No.</div>
          <div class="meta-value">{{receipt.number}}</div>
        </div>
        <div style="text-align:right;">
          <div class="meta-label">Date</div>
          <div class="meta-value">{{receipt.date}}</div>
        </div>
      </div>

      {{#if customer}}
      <div class="customer-block">
        <div class="customer-label">Customer</div>
        <div class="customer-name">{{customer.name}}</div>
        <div class="customer-email">{{customer.email}}</div>
      </div>
      {{/if}}

      <div class="divider"></div>

      <table class="items-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Qty</th>
            <th>Price</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          {{#each items}}
          <tr>
            <td>{{name}}</td>
            <td>{{quantity}}</td>
            <td>{{price}}</td>
            <td>{{amount}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="totals-block">
        <div class="total-row">
          <span>Subtotal</span>
          <span>{{totals.subtotal}}</span>
        </div>
        <div class="total-row">
          <span>Tax ({{totals.taxRate}})</span>
          <span>{{totals.tax}}</span>
        </div>
        {{#if totals.discount}}
        <div class="total-row">
          <span>Discount</span>
          <span>{{totals.discount}}</span>
        </div>
        {{/if}}
        <div class="grand-total">
          <span>Total</span>
          <span class="grand-total-accent">{{totals.total}}</span>
        </div>
      </div>

      <div class="divider"></div>

      <div class="payment-block">
        <div class="payment-label">Payment Method</div>
        <div class="payment-value">{{payment.method}}{{#if payment.cardDetails}} &mdash; {{payment.cardDetails}}{{/if}}</div>
      </div>

      {{#if barcode}}
      <div class="barcode-block">
        <div class="barcode-visual">{{barcode}}</div>
      </div>
      {{/if}}
    </div>

    <div class="receipt-footer">
      <p class="thank-you">{{footer.thankYouMessage}}</p>
      <p>{{footer.returnPolicy}}</p>
    </div>
  </div>
</body>
</html>
