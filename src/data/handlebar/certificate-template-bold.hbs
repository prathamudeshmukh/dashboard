<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #1e293b;
      line-height: 1.6;
      background-color: #f1f5f9;
      padding: 40px 20px;
    }
    .certificate-container {
      max-width: 800px;
      margin: 0 auto;
      background-color: #ffffff;
      border-left: 8px solid #f59e0b;
      text-align: center;
    }
    .certificate-banner {
      background-color: #0f172a;
      padding: 40px 72px 36px;
    }
    .cert-eyebrow {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 4px;
      color: #f59e0b;
      margin-bottom: 14px;
    }
    .cert-title {
      font-size: 32px;
      font-weight: 900;
      color: #ffffff;
      text-transform: uppercase;
      letter-spacing: 1px;
      line-height: 1.2;
    }
    .amber-rule { width: 80px; height: 4px; background-color: #f59e0b; margin: 20px auto 0; }
    .certificate-body { padding: 48px 72px 40px; }
    .cert-present-text { font-size: 15px; color: #64748b; margin-bottom: 12px; }
    .recipient-name {
      font-size: 38px;
      font-weight: 900;
      color: #0f172a;
      letter-spacing: -1px;
      margin-bottom: 28px;
      line-height: 1.15;
    }
    .amber-underline { width: 120px; height: 4px; background-color: #f59e0b; margin: 0 auto 28px; }
    .cert-description { font-size: 15px; color: #475569; margin-bottom: 12px; }
    .cert-program {
      font-size: 22px;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: 12px;
    }
    .cert-additional { font-size: 14px; color: #64748b; margin-bottom: 32px; font-style: italic; }
    .cert-date-block {
      display: inline-block;
      background: #0f172a;
      color: #f59e0b;
      font-size: 14px;
      font-weight: 700;
      padding: 10px 28px;
      margin-bottom: 48px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .signature-section {
      display: flex;
      justify-content: center;
      gap: 80px;
      margin-bottom: 40px;
    }
    .signature { width: 180px; text-align: center; }
    .signature-line { height: 3px; background-color: #0f172a; margin-bottom: 8px; }
    .signature-name { font-size: 14px; font-weight: 800; color: #0f172a; }
    .signature-title { font-size: 12px; color: #64748b; margin-top: 3px; font-weight: 500; }
    .cert-verification {
      background: #0f172a;
      display: inline-block;
      padding: 12px 24px;
      margin-bottom: 4px;
    }
    .verification-id { font-size: 12px; font-weight: 700; color: #f59e0b; font-family: monospace; letter-spacing: 1px; }
    .verification-text { font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 4px; }
    .certificate-footer {
      background: #0f172a;
      padding: 20px 72px;
      font-size: 12px;
      color: rgba(255,255,255,0.5);
    }
    .footer-org { font-weight: 700; color: #f59e0b; font-size: 13px; margin-bottom: 4px; }
  </style>
</head>
<body>
  <div class="certificate-container">
    <div class="certificate-banner">
      <div class="cert-eyebrow">{{certificate.type}}</div>
      <div class="cert-title">{{certificate.title}}</div>
      <div class="amber-rule"></div>
    </div>

    <div class="certificate-body">
      <div class="cert-present-text">{{achievement.description}}</div>
      <div class="recipient-name">{{recipient.prefix}} {{recipient.fullName}}</div>
      <div class="amber-underline"></div>
      <div class="cert-description">for successfully completing</div>
      <div class="cert-program">{{achievement.programName}}</div>
      <div class="cert-additional">{{achievement.additionalText}}</div>

      <div class="cert-date-block">Completed: {{details.completionDate}}</div>

      <div class="signature-section">
        {{#each signatures}}
        <div class="signature">
          <div class="signature-line"></div>
          <div class="signature-name">{{name}}</div>
          <div class="signature-title">{{title}}</div>
        </div>
        {{/each}}
      </div>

      <div class="cert-verification">
        <div class="verification-id">{{verification.id}}</div>
        <div class="verification-text">{{verification.verificationText}}</div>
      </div>
    </div>

    <div class="certificate-footer">
      <div class="footer-org">{{issuer.organization}}</div>
      <div>{{footer.address}}</div>
      <div>{{footer.contact}}</div>
    </div>
  </div>
</body>
</html>
