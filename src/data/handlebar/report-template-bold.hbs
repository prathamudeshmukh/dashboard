<!DOCTYPE html>
<html>
<head>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1e293b; background: #e2e8f0; padding: 24px; }
    .report-container { max-width: 800px; margin: 0 auto; background: #fff; box-shadow: 0 4px 24px rgba(0,0,0,0.15); border-left: 8px solid #f59e0b; }
    .report-header { background: #0f172a; color: #fff; padding: 40px; }
    .report-title { font-size: 28px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.5px; margin-bottom: 8px; }
    .report-subtitle { font-size: 15px; opacity: 0.75; margin-bottom: 4px; }
    .report-date { font-size: 12px; color: #f59e0b; font-weight: 600; }
    .report-body { padding: 40px; }
    .section { margin-bottom: 36px; }
    .section-title { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: #0f172a; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 3px solid #f59e0b; }
    .summary-box { background: #0f172a; color: #fff; padding: 20px; }
    .summary-box p { margin-bottom: 8px; font-size: 14px; line-height: 1.7; opacity: 0.9; }
    .chart-container { display: flex; gap: 8px; align-items: flex-end; height: 140px; margin-bottom: 24px; }
    .chart-bar { flex: 1; display: flex; flex-direction: column; align-items: center; }
    .bar { width: 100%; background: #0f172a; }
    .bar-label { font-size: 11px; color: #64748b; margin-top: 6px; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #0f172a; color: #fff; }
    th { padding: 12px 14px; text-align: left; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 10px 14px; font-size: 13px; border-bottom: 1px solid #e2e8f0; }
    .recommendations-list { list-style: none; }
    .recommendations-list li { padding: 10px 0; border-bottom: 1px solid #e2e8f0; font-size: 14px; display: flex; gap: 10px; }
    .recommendations-list li::before { content: "▶"; color: #f59e0b; flex-shrink: 0; font-size: 10px; margin-top: 3px; }
    .report-footer { background: #f8fafc; border-top: 3px solid #f59e0b; padding: 20px 40px; font-size: 12px; color: #475569; text-align: center; }
    .report-footer p + p { margin-top: 4px; }
  </style>
</head>
<body>
  <div class="report-container">
    <div class="report-header">
      <div class="report-title">{{header.title}}</div>
      <div class="report-subtitle">{{header.subtitle}}</div>
      <div class="report-date">{{header.date}}</div>
    </div>
    <div class="report-body">
      <div class="section">
        <div class="section-title">{{executiveSummary.title}}</div>
        <div class="summary-box">
          {{#each executiveSummary.paragraphs}}<p>{{this}}</p>{{/each}}
        </div>
      </div>
      <div class="section">
        <div class="section-title">{{financialOverview.title}}</div>
        <div class="chart-container">
          {{#each financialOverview.chartData}}
          <div class="chart-bar">
            <div class="bar" style="height:{{percentage}};"></div>
            <div class="bar-label">{{label}}</div>
          </div>
          {{/each}}
        </div>
        <table>
          <thead><tr>{{#each financialOverview.tableHeaders}}<th>{{this}}</th>{{/each}}</tr></thead>
          <tbody>
            {{#each financialOverview.tableRows}}
            <tr><td>{{metric}}</td><td>{{previousValue}}</td><td>{{currentValue}}</td><td>{{change}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      <div class="section">
        <div class="section-title">{{recommendations.title}}</div>
        <ul class="recommendations-list">
          {{#each recommendations.items}}<li>{{this}}</li>{{/each}}
        </ul>
      </div>
    </div>
    <div class="report-footer">
      <p>{{footer.preparedBy}}</p>
      <p>{{footer.confidentiality}}</p>
    </div>
  </div>
</body>
</html>
