<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{company.name}} — Brochure</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: #f8fafc;
      color: #0f172a;
      line-height: 1.6;
      border-left: 8px solid #f59e0b;
    }

    /* ── NAV ── */
    .nav {
      background: #0f172a;
      padding: 18px 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .nav-logo img {
      height: 36px;
      width: auto;
    }
    .nav-brand {
      font-size: 1.2rem;
      font-weight: 800;
      color: #f59e0b;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    /* ── HERO ── */
    .hero {
      background: #0f172a;
      color: #ffffff;
      padding: 100px 56px;
    }
    .hero-inner {
      max-width: 700px;
    }
    .hero-eyebrow {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #f59e0b;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-size: 3.6rem;
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: #ffffff;
      margin-bottom: 24px;
    }
    .hero p {
      font-size: 1.2rem;
      color: #94a3b8;
      margin-bottom: 40px;
      max-width: 520px;
    }
    .btn-amber {
      display: inline-block;
      background: #f59e0b;
      color: #0f172a;
      font-weight: 800;
      font-size: 0.95rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 16px 36px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-amber:hover { background: #d97706; }

    /* ── SECTION ── */
    .section {
      padding: 80px 56px;
    }
    .section--dark {
      background: #0f172a;
      color: #ffffff;
    }
    .section-inner {
      max-width: 1080px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #f59e0b;
      margin-bottom: 10px;
    }
    .section-title {
      font-size: 2.2rem;
      font-weight: 900;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }
    .section--dark .section-title { color: #ffffff; }
    .section-subtitle {
      font-size: 1rem;
      color: #64748b;
      margin-bottom: 48px;
    }
    .section--dark .section-subtitle { color: #94a3b8; }

    /* ── FEATURES ── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
    }
    .feature-card {
      background: #1e293b;
      padding: 32px 28px;
      border-top: 4px solid #f59e0b;
    }
    .feature-icon {
      font-size: 1.6rem;
      margin-bottom: 16px;
    }
    .feature-card h3 {
      font-size: 1.1rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 8px;
      letter-spacing: -0.01em;
    }
    .feature-card p {
      font-size: 0.92rem;
      color: #94a3b8;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    @media (max-width: 700px) { .about-grid { grid-template-columns: 1fr; } }
    .about-description {
      font-size: 0.97rem;
      color: #475569;
      margin-bottom: 20px;
    }
    .about-bullets {
      list-style: none;
      margin-top: 16px;
    }
    .about-bullets li {
      padding: 10px 0 10px 20px;
      position: relative;
      color: #0f172a;
      font-size: 0.95rem;
      font-weight: 600;
      border-bottom: 1px solid #e2e8f0;
    }
    .about-bullets li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 19px;
      width: 8px;
      height: 3px;
      background: #f59e0b;
    }
    .about-image {
      background: #1e293b;
      height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 0.85rem;
      overflow: hidden;
    }
    .about-image img { width: 100%; height: 100%; object-fit: cover; }

    /* ── TESTIMONIAL ── */
    .testimonial-section {
      background: #f59e0b;
      padding: 72px 56px;
      text-align: center;
    }
    .testimonial-quote {
      font-size: 1.6rem;
      font-weight: 700;
      font-style: italic;
      color: #0f172a;
      max-width: 700px;
      margin: 0 auto 24px;
      line-height: 1.4;
    }
    .testimonial-attribution {
      font-size: 0.9rem;
      font-weight: 700;
      color: #1e293b;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    /* ── PRODUCTS ── */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 28px;
    }
    .product-card {
      background: #ffffff;
      display: flex;
      flex-direction: column;
      box-shadow: 0 4px 16px rgba(0,0,0,.1);
    }
    .product-image {
      height: 180px;
      background: #1e293b;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #475569;
      font-size: 0.8rem;
      overflow: hidden;
    }
    .product-image img { width: 100%; height: 100%; object-fit: cover; }
    .product-body {
      padding: 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
      border-top: 4px solid #f59e0b;
    }
    .product-body h3 {
      font-size: 1.1rem;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: 8px;
    }
    .product-body p {
      font-size: 0.88rem;
      color: #64748b;
      flex: 1;
      margin-bottom: 14px;
    }
    .product-price {
      font-size: 1rem;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: 16px;
    }
    .btn-product {
      display: inline-block;
      background: #f59e0b;
      color: #0f172a;
      font-weight: 800;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 10px 20px;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
    }
    .btn-product:hover { background: #d97706; }

    /* ── CONTACT ── */
    .contact-methods {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-top: 16px;
    }
    .contact-method {
      background: #1e293b;
      padding: 28px 24px;
      border-top: 3px solid #f59e0b;
      text-align: center;
    }
    .contact-method .icon {
      font-size: 1.5rem;
      margin-bottom: 10px;
    }
    .contact-method h4 {
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #f59e0b;
      margin-bottom: 6px;
    }
    .contact-method p {
      font-size: 0.92rem;
      color: #94a3b8;
    }

    /* ── FOOTER ── */
    .footer {
      background: #0f172a;
      padding: 40px 56px;
      text-align: center;
    }
    .footer-social {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-bottom: 20px;
    }
    .footer-social a {
      color: #f59e0b;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .footer-social a:hover { color: #fbbf24; }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .footer-links a {
      color: #475569;
      text-decoration: none;
      font-size: 0.8rem;
    }
    .footer-links a:hover { color: #94a3b8; }
    .footer-copy {
      font-size: 0.78rem;
      color: #334155;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-logo">
      {{#if company.logoUrl}}
        <img src="{{company.logoUrl}}" alt="{{company.name}} logo" />
      {{/if}}
      <span class="nav-brand">{{company.name}}</span>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Creative Studio</p>
      <h1>{{hero.title}}</h1>
      <p>{{hero.subtitle}}</p>
      <a href="{{hero.ctaButton.url}}" class="btn-amber">{{hero.ctaButton.text}}</a>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section--dark">
    <div class="section-inner">
      <p class="section-label">What we offer</p>
      <h2 class="section-title">{{features.title}}</h2>
      <p class="section-subtitle">{{features.subtitle}}</p>
      <div class="features-grid">
        {{#each features.items}}
        <div class="feature-card">
          <div class="feature-icon">{{this.icon}}</div>
          <h3>{{this.title}}</h3>
          <p>{{this.description}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section">
    <div class="section-inner">
      <div class="about-grid">
        <div>
          <p class="section-label">About us</p>
          <h2 class="section-title">{{about.title}}</h2>
          <p class="about-description">{{about.description}}</p>
          <ul class="about-bullets">
            {{#each about.bulletPoints}}
            <li>{{this}}</li>
            {{/each}}
          </ul>
        </div>
        <div class="about-image">
          {{#if about.imageUrl}}
            <img src="{{about.imageUrl}}" alt="About {{company.name}}" />
          {{else}}
            Photo placeholder
          {{/if}}
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="testimonial-section">
    <p class="testimonial-quote">"{{testimonial.quote}}"</p>
    <p class="testimonial-attribution">
      {{testimonial.author}} &mdash; {{testimonial.company}}
    </p>
  </section>

  <!-- PRODUCTS -->
  <section class="section">
    <div class="section-inner">
      <p class="section-label">Services</p>
      <h2 class="section-title">{{products.title}}</h2>
      <p class="section-subtitle">{{products.subtitle}}</p>
      <div class="products-grid">
        {{#each products.items}}
        <div class="product-card">
          <div class="product-image">
            {{#if this.imageUrl}}
              <img src="{{this.imageUrl}}" alt="{{this.title}}" />
            {{else}}
              Image placeholder
            {{/if}}
          </div>
          <div class="product-body">
            <h3>{{this.title}}</h3>
            <p>{{this.description}}</p>
            <p class="product-price">{{this.price}}</p>
            <a href="{{this.buttonUrl}}" class="btn-product">{{this.buttonText}}</a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section section--dark">
    <div class="section-inner">
      <p class="section-label">Contact</p>
      <h2 class="section-title">{{contact.title}}</h2>
      <p class="section-subtitle">{{contact.subtitle}}</p>
      <div class="contact-methods">
        {{#each contact.methods}}
        <div class="contact-method">
          <div class="icon">{{this.icon}}</div>
          <h4>{{this.title}}</h4>
          <p>{{this.detail}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-social">
      {{#each socialLinks}}
        <a href="{{this.url}}">{{this.platform}}</a>
      {{/each}}
    </div>
    <div class="footer-links">
      {{#each footerLinks}}
        <a href="{{this.url}}">{{this.text}}</a>
      {{/each}}
    </div>
    <p class="footer-copy">{{copyright}}</p>
  </footer>

</body>
</html>
